{
  "name": "playwright-cucumber-framework",
  "version": "1.0.0",
  "description": "Playwright-BDD test automation framework in TypeScript.",
  "main": "index.js",
  "scripts": {
    "bddgen": "bddgen",
    "test": "bddgen && playwright test",
    "test:smoke": "bddgen && playwright test --grep @smoke",
    "test:visual": "bddgen && playwright test --grep @visual",
    "test:headed": "bddgen && playwright test --headed",
    "test:ui": "bddgen && playwright test --ui",
    "test:update-snapshots": "bddgen && playwright test --update-snapshots",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report",
    "report:cucumber": "open reports/cucumber-report.html",
    "clean:reports": "rm -rf .features-gen playwright-report test-results reports/cucumber-report.html reports/cucumber-report reports/data reports/trace"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.21",
    "dotenv": "^16.5.0",
    "playwright-bdd": "^9.2.0",
    "typescript": "^5.8.3"
  }
}
